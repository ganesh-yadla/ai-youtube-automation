ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://creator_os:creator_os@localhost:5432/creator_os
REDIS_URL=redis://localhost:6379/0

YOUTUBE_API_KEY=your_youtube_api_key_here

# LLM_PROVIDER selects which text-generation client is used: "gemini"
# (default, free tier available) or "claude". GEMINI_API_KEY is always
# required regardless of this setting - Voice Generation uses Gemini's TTS
# either way. ANTHROPIC_API_KEY is only required when LLM_PROVIDER=claude.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ffmpeg's drawtext filter needs an explicit font file on platforms without
# a working Fontconfig setup. Leave unset on Linux/Docker (fontconfig
# usually resolves a default there). On Windows, point this at a real
# .ttf, e.g. C:/Windows/Fonts/arial.ttf.
VIDEO_FONT_FILE=
