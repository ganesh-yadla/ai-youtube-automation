ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://creator_os:creator_os@localhost:5432/creator_os
REDIS_URL=redis://localhost:6379/0

YOUTUBE_API_KEY=your_youtube_api_key_here

# LLM_PROVIDER selects which text-generation client is used: "gemini"
# (default, free tier available) or "claude". GEMINI_API_KEY is always
# required regardless of this setting - Voice Generation uses Gemini's TTS
# either way. ANTHROPIC_API_KEY is only required when LLM_PROVIDER=claude.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ffmpeg's drawtext filter needs an explicit font file on platforms without
# a working Fontconfig setup. Leave unset on Linux/Docker (fontconfig
# usually resolves a default there). On Windows, point this at a real
# font file. IMPORTANT: pick a font with glyph coverage for every script
# you'll actually render - Arial has NO Telugu (or other Indic-script)
# glyphs, which renders as visible tofu boxes (☐☐) instead of letters, not
# an error, so it's easy to miss until you actually look at output. On
# Windows, C:/Windows/Fonts/Nirmala.ttc (bundled with the OS) covers both
# Latin and Telugu/Devanagari/etc. correctly - verified via real renders of
# both a thumbnail and an in-video caption in Telugu.
VIDEO_FONT_FILE=

# CONTENT_LANGUAGE is a whole-channel mode ("en" or "te"), not per-video.
# When "te": script generation is forced to Gemini regardless of
# LLM_PROVIDER (verified Ollama's Telugu quality is noticeably rougher),
# and PIPER_MODEL_PATH_TE is required if TTS_PROVIDER=piper - download a
# real Telugu voice, e.g. te_IN-maya-medium.onnx, from the same
# rhasspy/piper-voices catalog as the English one.
CONTENT_LANGUAGE=en
PIPER_MODEL_PATH_TE=
