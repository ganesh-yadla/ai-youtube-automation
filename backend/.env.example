ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://creator_os:creator_os@localhost:5432/creator_os
REDIS_URL=redis://localhost:6379/0

YOUTUBE_API_KEY=your_youtube_api_key_here

# LLM_PROVIDER selects which key below is required: "gemini" (default, free
# tier available) or "claude". Only the selected provider's key is validated.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
